{
  "name": "cc-mcp-lsp-java",
  "displayName": "CC MCP LSP Java",
  "description": "MCP server for Java - connects to VS Code's existing JDT.LS via LSP API",
  "publisher": "cc-mcp",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "mcp",
    "java",
    "jdtls",
    "lsp",
    "vscode"
  ],
  "extensionDependencies": [
    "redhat.java"
  ],
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:ccMcpLspJavaManagement",
    "onCommand:cc-mcp-lsp-java.openManagement"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ccMcpLspJavaSidebar",
          "title": "CC MCP LSP Java",
          "icon": "$(radio-tower)"
        }
      ]
    },
    "views": {
      "ccMcpLspJavaSidebar": [
        {
          "type": "webview",
          "id": "ccMcpLspJavaManagement",
          "name": "管理面板"
        }
      ]
    },
    "commands": [
      {
        "command": "cc-mcp-lsp-java.openManagement",
        "title": "CC MCP LSP Java: 打开管理面板"
      }
    ],
    "configuration": {
      "title": "CC MCP LSP Java",
      "properties": {
        "cc-mcp-lsp-java.port": {
          "type": "number",
          "default": 38765,
          "description": "Port for the MCP Streamable HTTP server."
        },
        "cc-mcp-lsp-java.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the MCP server."
        }
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "watch": "tsup --watch",
    "package": "vsce package",
    "compile": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.120.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "zod": "^3.23.0"
  },
  "files": [
    "dist"
  ]
}
