{
  "name": "cc-mcp-lsp-java",
  "displayName": "CC MCP LSP Java",
  "description": "MCP server for Java - connects to VS Code's existing JDT.LS via LSP API",
  "publisher": "gx-zyl",
  "version": "0.2.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/gx-zyl/cc-mcp-lsp-java.git"
  },
  "bugs": {
    "url": "https://github.com/gx-zyl/cc-mcp-lsp-java/issues"
  },
  "homepage": "https://github.com/gx-zyl/cc-mcp-lsp-java#readme",
  "license": "MIT",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "mcp",
    "java",
    "jdtls",
    "lsp",
    "vscode"
  ],
  "extensionDependencies": [
    "redhat.java"
  ],
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:ccMcpLspJavaManagement",
    "onView:ccMcpLspJavaDoc",
    "onView:ccMcpLspJavaTest",
    "onView:ccMcpLspJavaCallGraph",
    "onView:ccMcpLspJavaCallGraphDoc",
    "onCommand:cc-mcp-lsp-java.openManagement",
    "onCommand:cc-mcp-lsp-java.openCallGraph"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ccMcpLspJavaSidebar",
          "title": "CC MCP LSP Java",
          "icon": "$(radio-tower)"
        }
      ]
    },
    "views": {
      "ccMcpLspJavaSidebar": [
        {
          "type": "webview",
          "id": "ccMcpLspJavaManagement",
          "name": "管理面板"
        },
        {
          "type": "webview",
          "id": "ccMcpLspJavaDoc",
          "name": "MCP 接口说明"
        },
        {
          "type": "webview",
          "id": "ccMcpLspJavaTest",
          "name": "Java 查询测试"
        },
        {
          "type": "webview",
          "id": "ccMcpLspJavaCallGraph",
          "name": "调用图分析"
        },
        {
          "type": "webview",
          "id": "ccMcpLspJavaCallGraphDoc",
          "name": "调用图 MCP 接口说明"
        }
      ]
    },
    "commands": [
      {
        "command": "cc-mcp-lsp-java.openManagement",
        "title": "CC MCP LSP Java: 打开管理面板"
      },
      {
        "command": "cc-mcp-lsp-java.openCallGraph",
        "title": "CC MCP LSP Java: 打开调用图分析"
      },
      {
        "command": "cc-mcp-lsp-java.openCallGraphDoc",
        "title": "CC MCP LSP Java: 打开调用图 MCP 接口说明"
      }
    ],
    "configuration": {
      "title": "CC MCP LSP Java",
      "properties": {
        "cc-mcp-lsp-java.port": {
          "type": "number",
          "default": 38765,
          "description": "Port for the MCP Streamable HTTP server."
        },
        "cc-mcp-lsp-java.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the MCP server."
        },
        "cc-mcp-lsp-java.maxJars": {
          "type": "number",
          "default": 0,
          "description": "Limit JAR/class file count for scan (0=unlimited, max 5000). Recommended for projects with 1000+ files."
        },
        "cc-mcp-lsp-java.scanTimeout": {
          "type": "number",
          "default": 600,
          "description": "Scan timeout in seconds (default 600, 0=unlimited). Increase for large projects."
        },
        "cc-mcp-lsp-java.threads": {
          "type": "number",
          "default": 2,
          "description": "JACG parallel processing threads (1-16, default 2). Higher values use more CPU but may increase H2 write contention."
        },
        "cc-mcp-lsp-java.queryTimeout": {
          "type": "number",
          "default": 60,
          "description": "Query timeout in seconds (default 60, 0=unlimited)."
        }
      }
    }
  },
  "scripts": {
    "build:webview": "vite build",
    "build": "npm run build:webview && tsup",
    "watch": "tsup --watch",
    "watch:webview": "vite build --watch",
    "package": "vsce package",
    "compile": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.120.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vitejs/plugin-react": "^4.7.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vite": "^6.4.2",
    "zod": "^4.4.3"
  }
}
